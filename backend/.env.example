# ============================================
# Environment Variables Template
# Copy this file to .env.dev or .env.prod and update values
# ============================================

# ==========================================
# PostgreSQL
# ==========================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=portfolio_db

# URL для TypeORM / NestJS
# Для локальной разработки замени host на localhost
# Для Docker замени host на db
DATABASE_URL=postgresql://postgres:change_me_strong_password@localhost:5432/portfolio_db

# ==========================================
# Backend (NestJS)
# ==========================================
BACKEND_PORT=3001
NODE_ENV=development
JWT_SECRET=change_me_generate_strong_secret_minimum_32_characters
JWT_REFRESH_SECRET=change_me_generate_strong_secret_minimum_32_characters
JWT_EXPIRES_IN=7d
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3001

# ==========================================
# Frontend (Vite)
# ==========================================
VITE_API_URL=http://localhost:3001/api

# ==========================================
# Admin User (initial setup)
# ==========================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin