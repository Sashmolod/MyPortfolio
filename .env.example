# ============================================
# Переменные окружения для Portfolio Project
# Скопируйте этот файл в .env и заполните значения
# ============================================

# ==========================================
# PostgreSQL Database Configuration
# ==========================================
# Имя пользователя для базы данных
POSTGRES_USER=postgres

# Пароль для пользователя базы данных
# В production используйте сложный пароль!
POSTGRES_PASSWORD=postgres

# Имя базы данных
POSTGRES_DB=portfolio_db

# Хост базы данных (в Docker используем сервисное имя)
POSTGRES_HOST=db

# Порт базы данных
POSTGRES_PORT=5432

# URL подключения для приложения (используется TypeORM)
DATABASE_URL=postgresql://postgres:postgres@db:5432/portfolio_db

# ==========================================
# Backend (NestJS) Configuration
# ==========================================
# Порт, на котором работает NestJS внутри контейнера
BACKEND_PORT=3000

# Окружение Node.js
NODE_ENV=production

# Секрет для JWT токенов
# Сгенерируйте случайную строку:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Или через OpenSSL:
#   openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Время жизни JWT токена
JWT_EXPIRES_IN=7d

# CORS настройки (какие домены могут обращаться к API)
# Для разработки: http://localhost:5173, http://localhost:5174
# Для production укажите ваш домен
CORS_ORIGIN=http://localhost,http://frontend:80

# ==========================================
# Frontend (Vite) Configuration
# ==========================================
# URL бэкенда для API запросов из фронтенда
# В Docker используем сервисное имя backend
VITE_API_URL=http://backend:3000/api

# ==========================================
# Admin User Configuration (авто-создание при запуске)
# ==========================================
# Логин первого администратора
# Измените на свой!
ADMIN_USERNAME=admin

# Пароль первого администрала
# В production ОБЯЗАТЕЛЬНО измените!
ADMIN_PASSWORD=changeme-admin123

# ==========================================
# Nginx Configuration
# ==========================================
# Порт Nginx (внутри контейнера)
NGINX_PORT=80

# Хост Nginx
NGINX_SERVER_NAME=_
