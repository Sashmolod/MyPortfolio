# =====================
# Root .gitignore
# =====================

# Node modules
node_modules/
frontend/node_modules/
backend/node_modules/

# Environment files
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db
Desktop.ini

# IDE
.idea/
.vscode/
*.swp
*.swo

# Build output
dist/
build/
*.tsbuildinfo

# Docker (если нужно исключить)
.dockerignore

# Project specific
.orbstack/
orbstack*